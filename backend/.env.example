# Ollama Configuration for AI Copilot

# Set the Ollama base URL (default: http://localhost:11434)
# If running Ollama on a different host or port, update this
OLLAMA_BASE_URL=http://localhost:11434

# Set the Ollama model to use
# Available models: llama3, mistral, codellama, etc.
# Run `ollama list` to see installed models
OLLAMA_MODEL=llama3

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/sicms

# Security - MUST be at least 32 chars and not a placeholder. The app refuses
# to boot with a weak key unless DEBUG=true. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode (enables SQL logging; downgrades the SECRET_KEY check to a warning)
DEBUG=false

# CORS — comma-separated allowed origins. Leave empty when the frontend is
# served same-origin behind nginx (the default). e.g. https://soc.example.com
BACKEND_CORS_ORIGINS=

# Alert ingestion (/alerts/webhook) is authenticated per-webhook: each tenant
# can create one or more named webhooks (Settings > Integrations), each with its
# own X-API-Key. There is no global webhook key to configure here.

# Redis
REDIS_URL=redis://redis:6379

# Jira Integration (optional)
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_USER=your-email@example.com
# JIRA_API_TOKEN=your-api-token
